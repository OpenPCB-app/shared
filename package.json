{
  "name": "@openpcb/opclib-pack",
  "version": "0.1.0",
  "description": ".opclib archive pack + unpack: deterministic manifest digest, JSON Schema validation, ZIP extraction. Pure logic — no DB, no HTTP.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/*.json": "./dist/schemas/*.json"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bash scripts/copy-schemas.sh",
    "test": "bun test tests",
    "prepack": "npm run build",
    "prepare": "npm run build",
    "dev": "tsc -p tsconfig.build.json --watch"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenPCB-app/shared.git",
    "directory": "packages/opclib-pack"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "typescript": "^5.8.3"
  }
}
