{
  "name": "openpcb-shared",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Shared libraries for OpenPCB ecosystem (parsers, rendering, 3D conversion, canvas).",
  "license": "MIT",
  "repository": "github:OpenPCB-app/shared",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "tsc -b packages/*",
    "dev": "npm run dev --workspaces --if-present",
    "link:all": "bash scripts/link-all.sh",
    "unlink:all": "bash scripts/unlink-all.sh"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/bun": "^1.3.5"
  }
}
